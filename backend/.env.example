# ── Backend env example ──────────────────────────────────────────────────
# Copy to backend/.env and fill in real values. The .env file is gitignored.
# Anything tagged "optional" works without a value (the related feature is
# either off or falls back to a default).

# ── Database (required) ──────────────────────────────────────────────────
# Supabase connection string works out of the box. For local Postgres:
#   postgresql://USER:PASS@127.0.0.1:5432/subtracker
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Auth (required) ──────────────────────────────────────────────────────
# Long, random — `openssl rand -hex 32` is fine.
JWT_SECRET_KEY=change-me-to-a-long-random-secret
# Token lifetime. Default 30 days; the dashboard re-uses the JWT on every
# request and the threat model is "my own laptop", not "shared kiosk".
JWT_ACCESS_TOKEN_DAYS=30

# ── URLs (required) ──────────────────────────────────────────────────────
# Where the user-facing app lives — used in invite emails, magic links,
# unsubscribe pages. Localhost for dev, your Netlify URL for prod.
FRONTEND_URL=http://localhost:5173
# Where THIS API is reachable. Used by emails to build action links.
BACKEND_URL=http://localhost:5000
# Optional: comma-separated extra origins to allow via CORS (over and
# above FRONTEND_URL).
# CORS_ORIGINS=https://staging.example.com,https://preview.example.com

# ── Email (one of these — Resend wins if both are set) ──────────────────
# Option A: Resend (recommended — no 2FA hoops, free tier covers most apps)
# RESEND_API_KEY=re_xxx
# SMTP_FROM=hello@yourdomain.com

# Option B: SMTP (Gmail App Password, AWS SES, Mailgun…)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=you@gmail.com

# Skip email confirmation in dev — users land logged in straight after signup.
# Leave UNSET in production.
SKIP_EMAIL_CONFIRMATION=true

# ── Google SSO + Gmail sync (optional but recommended) ───────────────────
# Same client used for Google login + Gmail OAuth. Add your Netlify and
# localhost origins to the OAuth client's "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
# How far back to scan on first Gmail sync.
GMAIL_SYNC_LOOKBACK_DAYS=30

# ── Cron / scheduled emails (optional) ──────────────────────────────────
# The keep-warm pinger + nightly digest job in .github/workflows posts to
# /api/reminders/cron with this secret. If unset, the cron endpoint is
# effectively disabled.
CRON_SECRET=long-random-secret-shared-with-github-actions

# ── Expense Tracker — nudge rate limit (optional) ────────────────────────
# Max nudge emails one user can send in any rolling 24h window. Default 10.
NUDGE_DAILY_LIMIT=10
