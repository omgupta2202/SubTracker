# ── Python ────────────────────────────────────────────────────────────────
backend/venv/
backend/.venv/
backend/.env
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/instance/

# ── Node — frontend ───────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/.env.production

# ── Node — mobile (Expo) ──────────────────────────────────────────────────
mobile/node_modules/
mobile/.env
mobile/.env.local
mobile/dist/
mobile/.expo/
mobile/.expo-shared/

# Expo / EAS native artifacts (generated; not source)
mobile/android/
mobile/ios/
*.aab
*.apk
*.ipa

# ── Build caches that should never be committed ───────────────────────────
# Vite/webpack/Next caches sometimes leak in if a dev tool runs in the
# project root by mistake. Hard-block them.
.next/
**/.next/
.turbo/
.parcel-cache/
.cache/
.svelte-kit/
**/dist/
**/build/

# ── Editors / IDEs ────────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# ── Per-machine tool config (Claude Code, IDE workspaces, generic
#    settings.json that always seems to be machine-specific) ───────────────
.claude/
**/settings.json
.vscode/settings.json
.idea/

# ── OS ────────────────────────────────────────────────────────────────────
Thumbs.db
