# ── Frontend env example ─────────────────────────────────────────────────
# Copy to frontend/.env (or .env.local for per-machine overrides).
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# ── Required ─────────────────────────────────────────────────────────────
# Same client id as in backend/.env's GOOGLE_CLIENT_ID. The frontend uses
# this for Google SSO and the Gmail-connect button.
VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# ── Optional ─────────────────────────────────────────────────────────────
# Where the API lives. Defaults to "/api" so Vite's dev proxy (configured
# in vite.config.ts) forwards to the local backend in development. In
# production on Netlify we set this in the Netlify UI to the absolute URL
# of the deployed backend (e.g. https://subtracker-api.example.com/api),
# OR leave it as "/api" and rely on the Netlify redirect to proxy.
# VITE_API_BASE=/api

# .env.development (committed) sets VITE_API_BASE=/api so local dev
# always uses the proxy, regardless of what's in this file.
